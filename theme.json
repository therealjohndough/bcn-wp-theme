{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "appearanceTools": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#7CB342",
          "name": "Primary Green"
        },
        {
          "slug": "secondary",
          "color": "#4A90E2",
          "name": "Secondary Blue"
        },
        {
          "slug": "accent",
          "color": "#9C27B0",
          "name": "Accent Purple"
        },
        {
          "slug": "highlight",
          "color": "#FFC107",
          "name": "Highlight Yellow"
        },
        {
          "slug": "base",
          "color": "#FFFFFF",
          "name": "White"
        },
        {
          "slug": "contrast",
          "color": "#000000",
          "name": "Black"
        },
        {
          "slug": "text-primary",
          "color": "#000000",
          "name": "Text Primary"
        },
        {
          "slug": "text-secondary",
          "color": "#757575",
          "name": "Text Secondary"
        },
        {
          "slug": "background-subtle",
          "color": "#f5f5f5",
          "name": "Background Gray"
        },
        {
          "slug": "gray",
          "color": "#757575",
          "name": "Gray"
        },
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        },
        {
          "slug": "black",
          "color": "#000000",
          "name": "Black"
        }
      ],
      "gradients": [],
      "duotone": [],
      "custom": true,
      "customDuotone": true,
      "customGradient": true,
      "defaultGradients": false,
      "defaultPalette": false
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "'Roboto Flex', sans-serif",
          "slug": "primary",
          "name": "Roboto Flex"
        }
      ],
      "fontSizes": [
        {
          "slug": "small",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "normal",
          "size": "1rem",
          "name": "Normal"
        },
        {
          "slug": "medium",
          "size": "1.125rem",
          "name": "Medium"
        },
        {
          "slug": "large",
          "size": "1.25rem",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "1.5rem",
          "name": "Extra Large"
        },
        {
          "slug": "2xl",
          "size": "2rem",
          "name": "2X Large"
        },
        {
          "slug": "3xl",
          "size": "2.5rem",
          "name": "3X Large"
        },
        {
          "slug": "4xl",
          "size": "3rem",
          "name": "4X Large"
        },
        {
          "slug": "5xl",
          "size": "3.5rem",
          "name": "5X Large"
        },
        {
          "slug": "6xl",
          "size": "4.5rem",
          "name": "6X Large"
        }
      ],
      "customFontSize": true,
      "lineHeight": true,
      "fontWeight": true,
      "letterSpacing": true,
      "textTransform": true
    },
    "spacing": {
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingScale": {
        "steps": 0
      },
      "spacingSizes": [
        {
          "slug": "xs",
          "size": "0.5rem",
          "name": "Extra Small"
        },
        {
          "slug": "sm",
          "size": "1rem",
          "name": "Small"
        },
        {
          "slug": "md",
          "size": "1.5rem",
          "name": "Medium"
        },
        {
          "slug": "lg",
          "size": "2rem",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "3rem",
          "name": "Extra Large"
        },
        {
          "slug": "2xl",
          "size": "4rem",
          "name": "2X Large"
        },
        {
          "slug": "3xl",
          "size": "5rem",
          "name": "3X Large"
        },
        {
          "slug": "40",
          "size": "2.5rem",
          "name": "Spacing 40"
        },
        {
          "slug": "50",
          "size": "3rem",
          "name": "Spacing 50"
        },
        {
          "slug": "60",
          "size": "4rem",
          "name": "Spacing 60"
        },
        {
          "slug": "70",
          "size": "5rem",
          "name": "Spacing 70"
        }
      ],
      "padding": true,
      "margin": true,
      "blockGap": true
    },
    "border": {
      "radius": true,
      "color": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "slug": "sm",
          "shadow": "0 2px 8px rgba(0,0,0,0.1)",
          "name": "Small"
        },
        {
          "slug": "md",
          "shadow": "0 4px 16px rgba(0,0,0,0.15)",
          "name": "Medium"
        },
        {
          "slug": "lg",
          "shadow": "0 8px 24px rgba(0,0,0,0.2)",
          "name": "Large"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--text-primary)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--primary)",
      "fontSize": "var(--wp--preset--font-size--normal)",
      "lineHeight": "1.6",
      "fontWeight": "400"
    },
    "spacing": {
      "blockGap": "1.5rem",
      "padding": {
        "top": "0",
        "right": "0",
        "bottom": "0",
        "left": "0"
      }
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--secondary)"
          }
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "var(--wp--preset--color--base)"
        },
        "border": {
          "radius": "4px"
        },
        "spacing": {
          "padding": {
            "top": "1rem",
            "right": "2rem",
            "bottom": "1rem",
            "left": "2rem"
          }
        },
        "typography": {
          "fontWeight": "600",
          "fontSize": "1rem"
        },
        ":hover": {
          "color": {
            "background": "#4CAF50"
          },
          "shadow": "0 4px 12px rgba(124, 179, 66, 0.3)"
        }
      },
      "heading": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--primary)",
          "fontWeight": "600",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "var(--wp--preset--color--text-primary)"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--6-xl)",
          "fontWeight": "400"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--4-xl)",
          "fontWeight": "500"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--3-xl)",
          "fontWeight": "600"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--xl)",
          "fontWeight": "600"
        }
      }
    },
    "blocks": {
      "core/paragraph": {
        "color": {
          "text": "var(--wp--preset--color--text-secondary)"
        },
        "typography": {
          "lineHeight": "1.8"
        }
      },
      "core/button": {
        "border": {
          "radius": "4px"
        }
      },
      "core/group": {
        "spacing": {
          "padding": {
            "top": "0",
            "right": "0",
            "bottom": "0",
            "left": "0"
          }
        }
      }
    }
  },
  "customTemplates": [
    {
      "name": "page-about",
      "title": "About Page",
      "postTypes": ["page"]
    },
    {
      "name": "page-contact",
      "title": "Contact Page",
      "postTypes": ["page"]
    },
    {
      "name": "page-membership",
      "title": "Membership Page",
      "postTypes": ["page"]
    },
    {
      "name": "page-events",
      "title": "Events Page",
      "postTypes": ["page"]
    }
  ]
}